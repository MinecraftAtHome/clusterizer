{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.*\n        FROM\n            tasks t\n            JOIN assignments a ON\n                a.task_id = t.id\n            LEFT JOIN results r ON\n                r.assignment_id = a.id\n                AND r.state = 'init'\n        WHERE\n            a.state = 'submitted'\n        GROUP BY\n            t.id\n        HAVING\n            t.project_id = $1\n            AND count(a.id) >= t.assignments_needed\n            AND count(r.id) > 0\n        ",
